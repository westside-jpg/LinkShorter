# Скопируй этот файл в .env, он же используется и для Docker Compose,
# и для запуска сервера без докера (cp .env.example .env в корневой папке)

# --- База данных ---
# POSTGRES_USER, POSTGRES_PASSWORD и POSTGRES_DB нужны, чтобы поднять
# контейнер с PostgreSQL через Docker
POSTGRES_USER=linkshorter
POSTGRES_PASSWORD=change_me
POSTGRES_DB=linkshorter

# Используется только при запуске backend БЕЗ Docker.
# Если запускать через Docker Compose, то можно оставить как есть,
# backend автоматически соберёт свою строку подключения из POSTGRES_*.
DATABASE_URL=postgres://postgres:your-password@localhost:5432/linkshorter

# --- SMTP для отправки писем ---
# Инструкция по получению SMTP_PASSWORD для Gmail есть в README.md
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_symbol_app_password

# --- JWT ---
# Любая длинная случайная строка. Можно сгенерировать через openssl rand -base64 32
JWT_SECRET=change_me_to_a_long_random_string
